{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ApiFuck",
  "version": "0.0.6",
  "identifier": "me.tangge.apifuck",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ApiFuck",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tyuan511/apifuck/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGN0UwMzFFQkUzMjY2N0EKUldSNlpqSytIZ04rTCt5djZ0MXFqVG01N3NMT1JDTlp6cEpkTlZtR1RkNTA2elR2cFpMUENZbUYK"
    }
  }
}
